# chibi environment — copy to `.env` and fill in as needed.
#
# The AUTH / DATABASE section is entirely OPTIONAL. chibi runs fully without it
# (scenes persist locally in the browser). Set it up only to enable the auth
# addon (sign in; later: save/host scenes online). See docker-compose.yml.

# --- Auth / database (optional addon) -------------------------------------

# Postgres connection. Matches docker-compose.yml (host port 5487).
DATABASE_URL="postgres://chibi:chibi@localhost:5487/chibi"

# Session encryption secret (min 32 chars). Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Base URL of the app; used for OAuth callbacks and cookies.
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth (optional). Create an OAuth app at
# https://github.com/settings/developers with callback
# http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth (optional). Create credentials at
# https://console.cloud.google.com/apis/credentials with redirect
# http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Show the matching social sign-in buttons in the UI. Set to "true" once the
# corresponding *_CLIENT_ID / *_CLIENT_SECRET above are filled in.
NEXT_PUBLIC_AUTH_GITHUB="false"
NEXT_PUBLIC_AUTH_GOOGLE="false"
