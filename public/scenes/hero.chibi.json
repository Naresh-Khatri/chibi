{
  "chibi": 1,
  "name": "Hero scene",
  "root": ["nd_ground", "nd_cube", "nd_torus", "nd_key", "nd_fill"],
  "nodes": {
    "nd_ground": {
      "id": "nd_ground",
      "name": "Ground",
      "type": "mesh",
      "geometry": { "kind": "plane", "params": { "width": 24, "height": 24 } },
      "materialId": "mt_ground",
      "transform": {
        "position": [0, 0, 0],
        "rotation": [-1.5707963, 0, 0],
        "scale": [1, 1, 1]
      },
      "visible": true,
      "castShadow": false,
      "receiveShadow": true,
      "children": []
    },
    "nd_cube": {
      "id": "nd_cube",
      "name": "Cube",
      "type": "mesh",
      "geometry": {
        "kind": "box",
        "params": { "width": 1.2, "height": 1.2, "depth": 1.2 }
      },
      "materialId": "mt_pink",
      "transform": {
        "position": [0, 0.85, 0],
        "rotation": [0, 0.5235988, 0],
        "scale": [1, 1, 1]
      },
      "visible": true,
      "castShadow": true,
      "receiveShadow": true,
      "children": []
    },
    "nd_torus": {
      "id": "nd_torus",
      "name": "Torus",
      "type": "mesh",
      "geometry": {
        "kind": "torus",
        "params": { "radius": 0.6, "tube": 0.22, "radialSegments": 24, "tubularSegments": 96 }
      },
      "materialId": "mt_chrome",
      "transform": {
        "position": [-2.3, 0.85, -0.9],
        "rotation": [0.4, 0.2, 0],
        "scale": [1, 1, 1]
      },
      "visible": true,
      "castShadow": true,
      "receiveShadow": true,
      "children": []
    },
    "nd_key": {
      "id": "nd_key",
      "name": "Key light",
      "type": "light",
      "light": {
        "kind": "directional",
        "color": "#ffffff",
        "intensity": 2.5,
        "castShadow": true
      },
      "transform": {
        "position": [3, 5, 2],
        "rotation": [0, 0, 0],
        "scale": [1, 1, 1]
      },
      "visible": true,
      "children": []
    },
    "nd_fill": {
      "id": "nd_fill",
      "name": "Fill light",
      "type": "light",
      "light": {
        "kind": "point",
        "color": "#8fb8ff",
        "intensity": 14,
        "distance": 0,
        "castShadow": false
      },
      "transform": {
        "position": [-3.5, 2.5, -2],
        "rotation": [0, 0, 0],
        "scale": [1, 1, 1]
      },
      "visible": true,
      "children": []
    }
  },
  "materials": {
    "mt_ground": {
      "id": "mt_ground",
      "name": "Ground",
      "type": "standard",
      "color": "#15151c",
      "metalness": 0.05,
      "roughness": 0.9,
      "emissive": "#000000",
      "emissiveIntensity": 0,
      "opacity": 1,
      "transparent": false,
      "flatShading": false,
      "maps": { "map": null, "normalMap": null, "roughnessMap": null }
    },
    "mt_pink": {
      "id": "mt_pink",
      "name": "Pink",
      "type": "standard",
      "color": "#ff4d8d",
      "metalness": 0.15,
      "roughness": 0.35,
      "emissive": "#000000",
      "emissiveIntensity": 0,
      "opacity": 1,
      "transparent": false,
      "flatShading": false,
      "maps": { "map": null, "normalMap": null, "roughnessMap": null }
    },
    "mt_chrome": {
      "id": "mt_chrome",
      "name": "Chrome",
      "type": "standard",
      "color": "#c9ced9",
      "metalness": 0.9,
      "roughness": 0.15,
      "emissive": "#000000",
      "emissiveIntensity": 0,
      "opacity": 1,
      "transparent": false,
      "flatShading": false,
      "maps": { "map": null, "normalMap": null, "roughnessMap": null }
    }
  },
  "assets": {},
  "animations": {
    "an_float": {
      "id": "an_float",
      "name": "Float",
      "duration": 2,
      "loop": true,
      "tracks": [
        {
          "targetId": "nd_cube",
          "property": "transform.position",
          "keyframes": [
            { "t": 0, "v": [0, 0.85, 0], "ease": "easeInOut" },
            { "t": 1, "v": [0, 1.45, 0], "ease": "easeInOut" },
            { "t": 2, "v": [0, 0.85, 0] }
          ]
        },
        {
          "targetId": "nd_cube",
          "property": "transform.rotation",
          "keyframes": [
            { "t": 0, "v": [0, 0.5235988, 0], "ease": "easeInOut" },
            { "t": 2, "v": [0, 3.6651914, 0] }
          ]
        }
      ]
    }
  },
  "states": {
    "st_hot": {
      "id": "st_hot",
      "nodeId": "nd_cube",
      "name": "Hover",
      "overrides": {
        "nd_cube": { "transform.scale": [1.25, 1.25, 1.25] },
        "mt_pink": { "color": "#ffd24d" }
      }
    },
    "st_lift": {
      "id": "st_lift",
      "nodeId": "nd_torus",
      "name": "Lifted",
      "overrides": {
        "nd_torus": {
          "transform.position": [-2.3, 1.7, -0.9],
          "transform.rotation": [1.3, 0.7, 0]
        },
        "mt_chrome": { "color": "#7cf0ff" }
      }
    }
  },
  "interactions": [
    {
      "id": "ix_start_lift",
      "trigger": { "type": "start" },
      "action": {
        "type": "transition",
        "nodeId": "nd_torus",
        "to": "st_lift",
        "duration": 1.2,
        "ease": "easeOut"
      }
    },
    {
      "id": "ix_hover_in",
      "trigger": { "type": "hoverEnter", "nodeId": "nd_cube" },
      "action": {
        "type": "transition",
        "nodeId": "nd_cube",
        "to": "st_hot",
        "duration": 0.35,
        "ease": "easeOut"
      }
    },
    {
      "id": "ix_hover_out",
      "trigger": { "type": "hoverExit", "nodeId": "nd_cube" },
      "action": {
        "type": "transition",
        "nodeId": "nd_cube",
        "to": "base",
        "duration": 0.35,
        "ease": "easeOut"
      }
    },
    {
      "id": "ix_click_float",
      "trigger": { "type": "click", "nodeId": "nd_cube" },
      "action": { "type": "playAnimation", "animationId": "an_float" }
    },
    {
      "id": "ix_torus_toggle",
      "trigger": { "type": "click", "nodeId": "nd_torus" },
      "action": {
        "type": "toggleStates",
        "nodeId": "nd_torus",
        "a": "base",
        "b": "st_lift",
        "duration": 0.6,
        "ease": "easeInOut"
      }
    }
  ],
  "environment": {
    "background": "#0b0b0f",
    "preset": "city",
    "fog": null,
    "shadows": true
  },
  "camera": { "position": [4.5, 3, 6.5], "target": [-0.4, 0.9, 0], "fov": 45 },
  "editor": { "grid": true }
}
